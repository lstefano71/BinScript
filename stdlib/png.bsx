@default_endian(big)

@coverage(partial)
@root struct PngFile {
    signature: bytes[8],
    ihdr_length: u32,
    ihdr_type: fixed_string[4],
    ihdr: IhdrBody,
    ihdr_crc: u32,
}

struct IhdrBody {
    width: u32,
    height: u32,
    bit_depth: u8,
    color_type: u8,
    compression: u8,
    filter: u8,
    interlace: u8,
}
